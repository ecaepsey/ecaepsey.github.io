---
const { frontmatter } = Astro.props;

const dateFormatted = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{frontmatter.title} — Damir Aushenov</title>
    <meta name="description" content={frontmatter.description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;1,14..32,400&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: #ffffff;
        font-family: 'Inter', sans-serif;
        color: #111111;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      /* ── NAVBAR ── */
      .navbar {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid #f0f0f0;
        padding: 0 48px;
        height: 68px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .navbar-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        flex-shrink: 0;
      }

      .navbar-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        object-fit: cover;
        object-position: center top;
        border: 2px solid #e8e8e8;
      }

      .navbar-name {
        font-size: 17px;
        font-weight: 600;
        color: #111111;
        letter-spacing: -0.02em;
      }

      .navbar-links {
        display: flex;
        align-items: center;
        gap: 8px;
        list-style: none;
      }

      .navbar-links a {
        display: block;
        padding: 7px 16px;
        font-size: 15px;
        font-weight: 500;
        color: #555555;
        text-decoration: none;
        border-radius: 8px;
        transition: color 0.15s, background 0.15s;
      }

      .navbar-links a:hover,
      .navbar-links a.active {
        color: #111111;
        background: #f5f5f5;
      }

      .btn-hello {
        background: #111111;
        color: #ffffff;
        border: none;
        border-radius: 10px;
        padding: 10px 22px;
        font-size: 15px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s;
        letter-spacing: -0.01em;
        flex-shrink: 0;
      }

      .btn-hello:hover { background: #333333; }

      /* ── POST PAGE ── */
      .post-page {
        max-width: 680px;
        margin: 0 auto;
        padding: 64px 48px 100px;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        font-weight: 500;
        color: #888888;
        text-decoration: none;
        margin-bottom: 40px;
        transition: color 0.15s;
      }

      .back-link:hover { color: #111111; }

      .post-date {
        font-size: 13px;
        font-weight: 500;
        color: #aaaaaa;
        margin-bottom: 12px;
      }

      .post-title {
        font-size: clamp(28px, 4vw, 40px);
        font-weight: 800;
        color: #111111;
        letter-spacing: -0.03em;
        line-height: 1.15;
        margin-bottom: 16px;
      }

      .post-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 40px;
      }

      .badge {
        font-size: 12px;
        font-weight: 500;
        color: #555555;
        background: #f5f5f5;
        border-radius: 6px;
        padding: 4px 10px;
      }

      /* ── MARKDOWN CONTENT ── */
      .content { border-top: 1px solid #f0f0f0; padding-top: 40px; }

      .content h2 {
        font-size: 22px;
        font-weight: 700;
        color: #111111;
        letter-spacing: -0.02em;
        margin: 40px 0 14px;
      }

      .content h3 {
        font-size: 18px;
        font-weight: 600;
        color: #111111;
        margin: 28px 0 10px;
      }

      .content p {
        font-size: 16px;
        color: #333333;
        line-height: 1.75;
        margin-bottom: 18px;
      }

      .content ul, .content ol {
        padding-left: 24px;
        margin-bottom: 18px;
      }

      .content li {
        font-size: 16px;
        color: #333333;
        line-height: 1.75;
        margin-bottom: 6px;
      }

      .content strong { font-weight: 700; color: #111111; }

      .content code {
        font-family: 'SF Mono', 'Fira Code', monospace;
        font-size: 14px;
        background: #f5f5f5;
        border-radius: 4px;
        padding: 2px 6px;
        color: #111111;
      }

      .content pre {
        background: #f5f5f5;
        border-radius: 12px;
        padding: 20px 24px;
        overflow-x: auto;
        margin-bottom: 18px;
      }

      .content pre code {
        background: none;
        padding: 0;
        font-size: 14px;
      }

      .content hr {
        border: none;
        border-top: 1px solid #f0f0f0;
        margin: 32px 0;
      }

      .content a { color: #111111; font-weight: 500; }
      .content a:hover { opacity: 0.7; }

      @media (max-width: 640px) {
        .navbar { padding: 0 20px; }
        .navbar-links { display: none; }
        .post-page { padding: 48px 20px 80px; }
      }
    </style>
  </head>
  <body>

    <header class="navbar">
      <a href="/" class="navbar-brand">
        <img class="navbar-avatar" src="/avatar.jpg" alt="Damir Aushenov" />
        <span class="navbar-name">Damir Aushenov</span>
      </a>
      <nav>
        <ul class="navbar-links">
          <li><a href="/#projects">Projects</a></li>
          <li><a href="/#skills">Skills</a></li>
          <li><a href="/blog" class="active">Blog</a></li>
        </ul>
      </nav>
      <a href="/#contact" class="btn-hello">Say Hello</a>
    </header>

    <div class="post-page">
      <a href="/blog" class="back-link">← Back to Blog</a>
      <div class="post-date">{dateFormatted}</div>
      <h1 class="post-title">{frontmatter.title}</h1>
      {frontmatter.tags && (
        <div class="post-badges">
          {frontmatter.tags.map((tag: string) => <span class="badge">{tag}</span>)}
        </div>
      )}
      <div class="content">
        <slot />
      </div>
    </div>

  </body>
</html>
