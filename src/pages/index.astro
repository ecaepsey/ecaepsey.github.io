    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Damir Aushenov — iOS Developer" />
    <meta name="twitter:description" content="10 years building iOS apps in Swift and SwiftUI. Based in Bishkek, Kyrgyzstan." />
    <meta name="twitter:image" content="https://ecaepsey.github.io/og-dark.svg" />

    <!-- Structured data (Google rich results) -->
