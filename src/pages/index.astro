<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Damir Aushenov — iOS Developer in Bishkek</title>
    <meta name="description" content="Damir Aushenov is an iOS developer based in Bishkek with 10 years of experience building apps in Swift and SwiftUI. Available for freelance and full-time roles." />
    <meta name="keywords" content="iOS developer, Swift, SwiftUI, UIKit, mobile developer, Bishkek, Kyrgyzstan, freelance iOS" />
    <meta name="author" content="Damir Aushenov" />
    <link rel="canonical" href="https://ecaepsey.github.io/" />

    <!-- Open Graph (Facebook, LinkedIn, Telegram previews) -->
